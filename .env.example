# Lensora — Environment Variables Reference
# Copy this file to backend/.env and fill in your values.

# =========================================
# VISION AI — OPENROUTER (REQUIRED)
# =========================================

# OpenRouter API key — required for /api/analyze and /api/upload
# Get your key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Override the OpenRouter API base URL (optional — for proxies or self-hosting)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Active vision provider (openrouter | future: openai, gemini, anthropic, self-hosted)
VISION_PROVIDER=openrouter

# Primary model (used for all analysis requests)
# Full OpenRouter model identifier: provider/model-name
# Default: openai/gpt-5  |  Alternatives: openai/gpt-4o, google/gemini-2.5-pro
PRIMARY_MODEL=openai/gpt-5

# Secondary model (used only when verification is triggered)
SECONDARY_MODEL=google/gemini-2.5-pro

# =========================================
# DUAL-MODEL VERIFICATION
# =========================================

# Enable automatic dual-model accuracy verification (disabled by default)
# When false, verification still auto-triggers based on GPT uncertainty,
# question complexity, large question sets, or borderline image quality.
ENABLE_VERIFICATION=false

# Minimum question count that triggers automatic verification
LARGE_QUESTION_THRESHOLD=5

# =========================================
# FILE UPLOAD SETTINGS
# =========================================
MAX_FILE_SIZE_MB=10

# =========================================
# SERVER CONFIGURATION
# =========================================
CORS_ORIGINS=*

# Optional: used in OpenRouter HTTP-Referer header for analytics attribution
APP_URL=https://lensora.app

# =========================================
# AUTHENTICATION — SUPABASE
# =========================================
SUPABASE_JWT_SECRET=

# =========================================
# DATABASE (V1 — not actively used)
# =========================================
MONGO_URL=mongodb://localhost:27017
DB_NAME=lensora
